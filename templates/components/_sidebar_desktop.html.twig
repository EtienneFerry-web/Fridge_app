{# templates/components/_sidebar_desktop.html.twig #}
<aside class="desktop-sidebar bg-surface-low d-none d-md-flex flex-column p-4">
    <div class="d-flex flex-column align-items-center mb-5 pt-3 text-center">
        <div class="rounded-3 bg-{{ theme_color|default('primary') }}-custom bg-opacity-10 text-{{ theme_color|default('primary') }}-custom d-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
            <span class="material-symbols-outlined">{{ icon|default('grid_view') }}</span>
        </div>
        <h2 class="fs-5 fw-bolder text-{{ theme_color|default('primary') }}-custom font-headline mb-0">{{ app_name|default('The Living Larder') }}</h2>
        <p class="text-uppercase tracking-widest text-muted fw-bold" style="font-size: 10px; letter-spacing: 2px;">{{ household_name|default('Household') }}</p>
    </div>
    
    <nav class="d-flex flex-column gap-2 flex-grow-1 font-headline">
        <a href="{{ path('app_hub')|default('#') }}" class="d-flex align-items-center gap-3 text-decoration-none px-4 py-3 rounded-pill {% if active_page|default('hub') == 'hub' %}text-{{ theme_color|default('primary') }}-custom bg-surface-lowest shadow-sm{% else %}text-muted hover-bg-white transition{% endif %}">
            <span class="material-symbols-outlined">grid_view</span> <span class="{% if active_page|default('hub') == 'hub' %}fw-bold{% else %}fw-medium{% endif %}">Hub</span>
        </a>
        <a href="{{ path('app_grocery_list')|default('#') }}" class="d-flex align-items-center gap-3 text-decoration-none px-4 py-3 rounded-pill {% if active_page|default('') == 'groceries' %}text-{{ theme_color|default('primary') }}-custom bg-surface-lowest shadow-sm{% else %}text-muted hover-bg-white transition{% endif %}">
            <span class="material-symbols-outlined">shopping_basket</span> <span class="{% if active_page|default('') == 'groceries' %}fw-bold{% else %}fw-medium{% endif %}">Grocery List</span>
        </a>
        <a href="{{ path('app_profile')|default('#') }}" class="d-flex align-items-center gap-3 text-decoration-none px-4 py-3 rounded-pill {% if active_page|default('') == 'profile' %}text-{{ theme_color|default('primary') }}-custom bg-surface-lowest shadow-sm{% else %}text-muted hover-bg-white transition{% endif %}">
            <span class="material-symbols-outlined">person_2</span> <span class="{% if active_page|default('') == 'profile' %}fw-bold{% else %}fw-medium{% endif %}">Personal Space</span>
        </a>
        <a href="{{ path('app_discovery')|default('#') }}" class="d-flex align-items-center gap-3 text-decoration-none px-4 py-3 rounded-pill {% if active_page|default('') == 'discovery' %}text-{{ theme_color|default('primary') }}-custom bg-surface-lowest shadow-sm{% else %}text-muted hover-bg-white transition{% endif %}">
            <span class="material-symbols-outlined">explore</span> <span class="{% if active_page|default('') == 'discovery' %}fw-bold{% else %}fw-medium{% endif %}">Discovery</span>
        </a>
        <a href="{{ path('app_admin')|default('#') }}" class="d-flex align-items-center gap-3 text-decoration-none px-4 py-3 rounded-pill {% if active_page|default('') == 'admin' %}text-{{ theme_color|default('primary') }}-custom bg-surface-lowest shadow-sm{% else %}text-muted hover-bg-white transition{% endif %}">
            <span class="material-symbols-outlined">settings</span> <span class="{% if active_page|default('') == 'admin' %}fw-bold{% else %}fw-medium{% endif %}">Admin</span>
        </a>
    </nav>
    
    <button class="btn bg-secondary-custom text-white rounded-pill py-3 fw-bold d-flex align-items-center justify-content-center gap-2 mt-auto shadow">
        <span class="material-symbols-outlined">add</span> Add to Plan
    </button>
</aside>
