{# templates/components/_header_mobile.html.twig #}
<header class="sticky-top bg-glass d-md-none z-3 border-bottom border-light">
    <div class="container px-4 py-3 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-primary-custom fs-4">eco</span>
            <h1 class="font-headline fw-bold m-0 fs-5 text-primary-custom">{{ title|default('The Organic Curator') }}</h1>
        </div>
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link p-0 text-on-surface-variant">
                <span class="material-symbols-outlined">search</span>
            </button>
            <div class="rounded-circle overflow-hidden border border-success border-2 shadow-sm" style="width: 36px; height: 36px;">
                <img src="{{ user_avatar|default('https://ui-avatars.com/api/?name=User&background=random') }}" alt="Profile" class="w-100 h-100 object-fit-cover">
            </div>
        </div>
    </div>
</header>
