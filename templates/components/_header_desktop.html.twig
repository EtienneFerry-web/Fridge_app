{# templates/components/_header_desktop.html.twig #}
<header class="fixed-top bg-surface d-none d-md-flex justify-content-between align-items-center w-100 px-4 py-3 z-3">
    <div class="d-flex align-items-center gap-3">
        <span class="fs-5 fw-bold text-primary-custom font-headline">{{ title|default('The Culinary Curator') }}</span>
    </div>
    <div class="bg-surface-low rounded-pill px-3 py-2 w-25 d-flex align-items-center border border-light">
        <span class="material-symbols-outlined text-muted me-2">search</span>
        <input type="text" class="form-control bg-transparent border-0 p-0 shadow-none font-body text-sm" placeholder="{{ search_placeholder|default('Search seasonal ingredients...') }}">
    </div>
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-link p-2 text-primary-custom rounded-circle hover-bg-light"><span class="material-symbols-outlined">group</span></button>
        <button class="btn btn-link p-2 text-primary-custom rounded-circle hover-bg-light"><span class="material-symbols-outlined">notifications</span></button>
        <div class="rounded-circle overflow-hidden bg-light shadow-sm" style="width: 40px; height: 40px;">
            <img src="{{ user_avatar|default('https://ui-avatars.com/api/?name=User&background=random') }}" alt="Avatar" class="w-100 h-100 object-fit-cover">
        </div>
    </div>
</header>
