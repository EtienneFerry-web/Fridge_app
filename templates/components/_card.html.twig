{# templates/components/_card.html.twig #}
<article class="card h-100 border-0 bg-surface-lowest rounded-2xl hover-lift shadow-sm {{ extra_classes|default('') }}">
    {% if image_url is defined and image_url %}
    <div class="card-img-wrapper position-relative rounded-top-4" style="height: {{ image_height|default('220px') }};">
        <img src="{{ image_url }}" class="w-100 h-100 object-fit-cover" alt="{{ image_alt|default(title|default('Image')) }}">
        {% if badge_text is defined and badge_text %}
        <div class="position-absolute top-0 end-0 m-3 bg-glass px-2 py-1 rounded-pill d-flex align-items-center gap-1 shadow-sm">
            {% if badge_icon is defined and badge_icon %}
            <span class="material-symbols-outlined text-primary-custom" style="font-size: 16px;">{{ badge_icon }}</span>
            {% endif %}
            <span class="fw-bold text-dark text-uppercase" style="font-size: 10px;">{{ badge_text }}</span>
        </div>
        {% endif %}
    </div>
    {% endif %}
    
    <div class="card-body p-4 d-flex flex-column">
        {% if category is defined or rating is defined %}
        <div class="d-flex justify-content-between align-items-center mb-2">
            {% if category is defined %}
            <span class="text-secondary-custom fw-bold text-uppercase" style="font-size: 10px; letter-spacing: 1.5px;">{{ category }}</span>
            {% endif %}
            {% if rating is defined %}
            <div class="d-flex align-items-center gap-1">
                <span class="material-symbols-outlined text-secondary-custom" style="font-size: 16px; font-variation-settings: 'FILL' 1;">star</span>
                <span class="fw-bold fs-6">{{ rating }}</span>
            </div>
            {% endif %}
        </div>
        {% endif %}

        {% if title is defined %}
        <h3 class="font-headline fs-5 fw-bold mb-2">{{ title }}</h3>
        {% endif %}

        {% if description is defined %}
        <p class="text-on-surface-variant small mb-4">{{ description }}</p>
        {% endif %}
        
        {% block card_content %}{% endblock %}

        {% if block('card_footer') is defined %}
        <div class="mt-auto d-flex justify-content-between align-items-center border-top pt-3">
            {% block card_footer %}{% endblock %}
        </div>
        {% endif %}
    </div>
</article>
